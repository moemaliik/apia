# ---- LLM ----------------------------------------------------------------
APIA_LLM_PROVIDER=replay          # anthropic | openai | gemini | replay
APIA_LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...              # only if APIA_LLM_PROVIDER=openai
# GEMINI_API_KEY=...                 # only if APIA_LLM_PROVIDER=gemini

# ---- GitHub -------------------------------------------------------------
APIA_GITHUB_MODE=mock                # real | mock
GITHUB_TOKEN=ghp_...                 # a fine-grained PAT with issues:read/write on the repo
GITHUB_REPO=your-username/your-sandbox-repo

# ---- behaviour knobs (optional; defaults shown) -------------------------
# APIA_MAX_SYNTH_ATTEMPTS=3
# APIA_MAX_STEP_RETRIES=2
# APIA_PROMOTE_AFTER=3
# APIA_DEPRECATE_AFTER=2
# APIA_COMPACT_AFTER=8
# APIA_MAX_API_CALLS=40
